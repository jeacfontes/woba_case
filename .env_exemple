# =========================================================
# WOBA ANALYTICS PIPELINE - ENVIRONMENT VARIABLES (MOCK)
# =========================================================

# -----------------
# AWS / ATHENA & ICEBERG
# -----------------
AWS_ACCESS_KEY_ID=mock_aws_access_key_123
AWS_SECRET_ACCESS_KEY=mock_aws_secret_key_456
AWS_REGION=us-east-1

# Schema principal do Data Warehouse no Athena
ATHENA_DATABASE=woba_dw
ATHENA_S3_STAGING_DIR=s3://woba-dbt-artifacts/athena-query-results/

# -----------------
# DBT CONFIGURATION
# -----------------
# Aponta para o diretório local onde está o profiles.yml
DBT_PROFILES_DIR=./dags/dbt/woba_bookings_dbt
DBT_PROJECT_DIR=./dags/dbt/woba_bookings_dbt

# -----------------
# CI/CD & ARTIFACTS
# -----------------
S3_ARTIFACTS_BUCKET=s3://woba-dbt-artifacts/prod/

# -----------------
# ASTRONOMER / AIRFLOW (DEPLOY)
# -----------------
ASTRONOMER_WORKSPACE_ID=mock_astro_ws_789
ASTRONOMER_DEPLOYMENT_ID=mock_astro_dep_101
ASTRONOMER_KEY_ID=mock_astro_key_id
ASTRONOMER_KEY_SECRET=mock_astro_key_secret
